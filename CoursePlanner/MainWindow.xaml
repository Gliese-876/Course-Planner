<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="CoursePlanner.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:CoursePlanner"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:services="using:CoursePlanner.Services"
    Title=""
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid
        x:Name="ShellRoot"
        services:AppMaterialLayer.Surface="WindowBackdrop"
        UseLayoutRounding="True">
        <NavigationView
            x:Name="RootNavigation"
            services:AppMaterialLayer.Surface="NavigationRail"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            IsPaneOpen="False"
            IsTitleBarAutoPaddingEnabled="False"
            PaneDisplayMode="LeftCompact"
            SelectionChanged="RootNavigation_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="PlannerItem" AutomationProperties.AutomationId="PlannerItem" Icon="Calendar" Tag="planner" />
                <NavigationViewItem x:Name="SemestersItem" AutomationProperties.AutomationId="SemestersItem" Icon="Calendar" Tag="semesters" />
                <NavigationViewItem x:Name="LibraryItem" AutomationProperties.AutomationId="LibraryItem" Icon="Library" Tag="library" />
                <NavigationViewItem x:Name="LabelsItem" AutomationProperties.AutomationId="LabelsItem" Tag="labels">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8EC;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="PlansItem" AutomationProperties.AutomationId="PlansItem" Icon="Document" Tag="plans" />
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <NavigationViewItem x:Name="SettingsItem" AutomationProperties.AutomationId="SettingsItem" Icon="Setting" Tag="settings" />
            </NavigationView.FooterMenuItems>
            <Grid RowDefinitions="40,*">
                <Grid
                    x:Name="ShellTitleBar"
                    Padding="0,0,140,0"
                    services:AppMaterialLayer.Surface="Chrome">
                    <Grid
                        x:Name="ShellAppBrand"
                        AutomationProperties.AutomationId="ShellAppBrand"
                        Canvas.ZIndex="2"
                        ColumnDefinitions="Auto,*"
                        ColumnSpacing="10"
                        Height="40"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
                        <Image
                            Width="24"
                            Height="24"
                            VerticalAlignment="Center"
                            Source="Assets/Square44x44Logo.scale-200.png"
                            Stretch="Uniform" />
                        <TextBlock
                            x:Name="ShellAppTitleText"
                            AutomationProperties.AutomationId="ShellAppTitleText"
                            Grid.Column="1"
                            Height="{ThemeResource AppBodyStrongTextLineHeight}"
                            LineHeight="{ThemeResource AppBodyStrongTextLineHeight}"
                            LineStackingStrategy="BlockLineHeight"
                            VerticalAlignment="Center"
                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                            Text=""
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap" />
                    </Grid>
                    <Grid
                        x:Name="ShellPlanTabs"
                        services:AppMaterialLayer.Surface="ShellTabRail"
                        AutomationProperties.AccessibilityView="Control"
                        AutomationProperties.AutomationId="ShellPlanTabs"
                        AutomationProperties.Name="ShellPlanTabs"
                        Canvas.ZIndex="1"
                        Height="40"
                        ColumnDefinitions="Auto,*"
                        HorizontalAlignment="Stretch"
                        Padding="8,4,4,0"
                        VerticalAlignment="Bottom">
                        <Grid
                            x:Name="ShellPlanTabStripHost"
                            ColumnDefinitions="Auto,Auto"
                            ColumnSpacing="4"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom">
                            <ScrollViewer
                                x:Name="ShellPlanTabScrollViewer"
                                HorizontalAlignment="Left"
                                HorizontalScrollBarVisibility="Hidden"
                                HorizontalScrollMode="Enabled"
                                VerticalScrollBarVisibility="Disabled"
                                VerticalScrollMode="Disabled">
                                <StackPanel
                                    x:Name="ShellPlanTabItems"
                                    Height="36"
                                    Orientation="Horizontal" />
                            </ScrollViewer>
                            <Button
                                x:Name="ShellAddPlanTabButton"
                                AutomationProperties.AutomationId="ShellAddPlanTabButton"
                                Grid.Column="1"
                                Width="30"
                                Height="30"
                                Padding="0"
                                HorizontalContentAlignment="Center"
                                VerticalAlignment="Center"
                                VerticalContentAlignment="Center"
                                Background="{ThemeResource SubtleFillColorTransparentBrush}"
                                BorderThickness="0"
                                Click="ShellAddPlanTabButton_Click">
                                <FontIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Glyph="&#xE710;" />
                            </Button>
                        </Grid>
                    </Grid>
                </Grid>
                <Frame
                    x:Name="RootFrame"
                    Grid.Row="1"
                    services:AppMaterialLayer.Surface="Page" />
            </Grid>
        </NavigationView>
        <InfoBar
            x:Name="RuntimeOperationErrorBar"
            AutomationProperties.AutomationId="RuntimeOperationErrorBar"
            AutomationProperties.LiveSetting="Assertive"
            Canvas.ZIndex="100"
            MinWidth="320"
            MaxWidth="960"
            Margin="24,48,24,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            IsClosable="True"
            IsOpen="False"
            Severity="Error">
            <InfoBar.ActionButton>
                <Button
                    x:Name="RuntimeOperationRecoveryButton"
                    AutomationProperties.AutomationId="RuntimeOperationRecoveryButton"
                    Click="RuntimeOperationRecoveryButton_Click"
                    IsEnabled="False"
                    Visibility="Collapsed" />
            </InfoBar.ActionButton>
        </InfoBar>
    </Grid>
</Window>
