<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="CoursePlanner.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:appControls="using:CoursePlanner.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    SizeChanged="Page_SizeChanged"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="SettingsRowCardStyle" TargetType="Border" BasedOn="{StaticResource AppCardSurfaceStyle}">
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="SettingsDescriptionTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Page.Resources>

    <Grid
        x:Name="SettingsRootGrid"
        Style="{StaticResource ManagementRootGridStyle}">

        <ScrollViewer
            x:Name="SettingsScrollViewer"
            AutomationProperties.AutomationId="SettingsScrollViewer"
            Style="{StaticResource ManagementScrollViewerStyle}">
            <Grid x:Name="SettingsContentHost" AutomationProperties.AutomationId="SettingsContentHost">
                <Grid
                    x:Name="SettingsContentRoot"
                    AutomationProperties.AutomationId="SettingsContentRoot"
                    HorizontalAlignment="Center"
                    RowDefinitions="Auto,Auto,Auto,Auto"
                    RowSpacing="28">
                    <TextBlock
                        x:Name="SettingsTitle"
                        Margin="0,4,0,0"
                        Style="{ThemeResource TitleTextBlockStyle}"
                        Text="" />

                    <Grid
                        Grid.Row="1"
                        RowDefinitions="Auto,Auto"
                        RowSpacing="8">
                        <TextBlock x:Name="GeneralTitle" Style="{ThemeResource SubtitleTextBlockStyle}" Text="" />
                        <StackPanel Grid.Row="1" Spacing="8">
                            <Border x:Name="LanguageCard" Style="{StaticResource SettingsRowCardStyle}">
                                <Grid x:Name="LanguageCardLayout" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="20" RowSpacing="10">
                                    <TextBlock x:Name="LanguageTitleText" Style="{ThemeResource BodyStrongTextBlockStyle}" Text="" />
                                    <TextBlock x:Name="LanguageDescriptionText" Grid.Row="1" Style="{StaticResource SettingsDescriptionTextStyle}" Text="" />
                                    <appControls:WheelSafeComboBox
                                        x:Name="LanguageBox"
                                        AutomationProperties.AutomationId="LanguageBox"
                                        Grid.Column="1"
                                        Grid.RowSpan="2"
                                        Width="240"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        SelectionChanged="LanguageBox_SelectionChanged" />
                                </Grid>
                            </Border>
                            <Border x:Name="ThemeCard" Style="{StaticResource SettingsRowCardStyle}">
                                <Grid x:Name="ThemeCardLayout" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="20" RowSpacing="10">
                                    <TextBlock x:Name="ThemeTitleText" Style="{ThemeResource BodyStrongTextBlockStyle}" Text="" />
                                    <TextBlock x:Name="ThemeDescriptionText" Grid.Row="1" Style="{StaticResource SettingsDescriptionTextStyle}" Text="" />
                                    <appControls:WheelSafeComboBox
                                        x:Name="ThemeBox"
                                        AutomationProperties.AutomationId="ThemeBox"
                                        Grid.Column="1"
                                        Grid.RowSpan="2"
                                        Width="240"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        SelectionChanged="ThemeBox_SelectionChanged" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Grid
                        Grid.Row="2"
                        RowDefinitions="Auto,Auto"
                        RowSpacing="8">
                        <TextBlock x:Name="DataTitle" Style="{ThemeResource SubtitleTextBlockStyle}" Text="" />
                        <StackPanel Grid.Row="1" Spacing="8">
                            <Border x:Name="DatabaseCard" Style="{StaticResource SettingsRowCardStyle}">
                                <Grid x:Name="DatabaseCardLayout" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="20" RowSpacing="10">
                                    <TextBlock x:Name="DatabaseTitleText" Style="{ThemeResource BodyStrongTextBlockStyle}" Text="" />
                                    <TextBlock x:Name="DatabaseDescriptionText" Grid.Row="1" Style="{StaticResource SettingsDescriptionTextStyle}" Text="" />
                                    <Button
                                        x:Name="OpenDatabaseButton"
                                        AutomationProperties.AutomationId="OpenDatabaseButton"
                                        Grid.Column="1"
                                        Grid.RowSpan="2"
                                        Content=""
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Click="OpenDatabase_Click" />
                                </Grid>
                            </Border>
                            <Border x:Name="BackupCard" Style="{StaticResource SettingsRowCardStyle}">
                                <Grid x:Name="BackupCardLayout" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="20" RowSpacing="10">
                                    <TextBlock x:Name="BackupTitleText" Style="{ThemeResource BodyStrongTextBlockStyle}" Text="" />
                                    <TextBlock x:Name="BackupDescriptionText" Grid.Row="1" Style="{StaticResource SettingsDescriptionTextStyle}" Text="" />
                                    <StackPanel
                                        x:Name="BackupActionsPanel"
                                        Grid.Column="1"
                                        Grid.RowSpan="2"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                        <Button
                                            x:Name="BackupButton"
                                            AutomationProperties.AutomationId="BackupButton"
                                            Content=""
                                            Click="Backup_Click" />
                                        <Button
                                            x:Name="RestoreButton"
                                            AutomationProperties.AutomationId="RestoreButton"
                                            Content=""
                                            Click="Restore_Click" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Grid
                        Grid.Row="3"
                        Margin="0,0,0,32"
                        RowDefinitions="Auto,Auto"
                        RowSpacing="8">
                        <TextBlock x:Name="SoftwareInformationTitle" Style="{ThemeResource SubtitleTextBlockStyle}" Text="" />
                        <StackPanel x:Name="SoftwareInformationCards" Grid.Row="1" Spacing="8">
                            <Border
                                x:Name="AppInformationCard"
                                AutomationProperties.AutomationId="AppInformationCard"
                                Style="{StaticResource SettingsRowCardStyle}">
                                <Grid
                                    x:Name="AppInformationCardLayout"
                                    ColumnDefinitions="*,Auto"
                                    RowDefinitions="Auto,Auto,Auto"
                                    ColumnSpacing="20"
                                    RowSpacing="10">
                                    <TextBlock x:Name="AppNameText" Style="{ThemeResource BodyStrongTextBlockStyle}" Text="" />
                                    <TextBlock x:Name="AppDescriptionText" Grid.Row="1" Style="{StaticResource SettingsDescriptionTextStyle}" Text="" />
                                    <TextBlock
                                        x:Name="AppVersionText"
                                        Grid.Column="1"
                                        Grid.RowSpan="2"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource SettingsDescriptionTextStyle}"
                                        Text="" />
                                </Grid>
                            </Border>
                            <Border x:Name="PublisherCard" Style="{StaticResource SettingsRowCardStyle}">
                                <Grid x:Name="PublisherCardLayout" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="20" RowSpacing="10">
                                    <TextBlock x:Name="PublisherTitleText" Style="{ThemeResource BodyStrongTextBlockStyle}" Text="" />
                                    <TextBlock x:Name="PublisherNameText" Grid.Row="1" Style="{StaticResource SettingsDescriptionTextStyle}" Text="" />
                                    <Button
                                        x:Name="OpenPublisherProfileButton"
                                        AutomationProperties.AutomationId="OpenPublisherProfileButton"
                                        Grid.Column="1"
                                        Grid.RowSpan="2"
                                        Content=""
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Click="OpenPublisherProfile_Click" />
                                </Grid>
                            </Border>
                            <Border x:Name="ProjectLicenseCard" Style="{StaticResource SettingsRowCardStyle}">
                                <Grid x:Name="ProjectLicenseCardLayout" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="20" RowSpacing="10">
                                    <TextBlock x:Name="ProjectLicenseTitleText" Style="{ThemeResource BodyStrongTextBlockStyle}" Text="" />
                                    <TextBlock x:Name="ProjectLicenseDescriptionText" Grid.Row="1" Style="{StaticResource SettingsDescriptionTextStyle}" Text="" />
                                    <Button
                                        x:Name="ViewProjectLicenseButton"
                                        AutomationProperties.AutomationId="ViewProjectLicenseButton"
                                        Grid.Column="1"
                                        Grid.RowSpan="2"
                                        Content=""
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Click="ViewProjectLicense_Click" />
                                </Grid>
                            </Border>
                            <Border x:Name="LicensesCard" Style="{StaticResource SettingsRowCardStyle}">
                                <Grid x:Name="LicensesCardLayout" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="20" RowSpacing="10">
                                    <TextBlock x:Name="LicensesTitleText" Style="{ThemeResource BodyStrongTextBlockStyle}" Text="" />
                                    <TextBlock x:Name="LicensesDescriptionText" Grid.Row="1" Style="{StaticResource SettingsDescriptionTextStyle}" Text="" />
                                    <Button
                                        x:Name="ViewLicensesButton"
                                        AutomationProperties.AutomationId="ViewLicensesButton"
                                        Grid.Column="1"
                                        Grid.RowSpan="2"
                                        Content=""
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Click="ViewLicenses_Click" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
