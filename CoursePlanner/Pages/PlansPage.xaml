<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="CoursePlanner.Pages.PlansPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:appControls="using:CoursePlanner.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="using:CoursePlanner.Pages"
    Background="Transparent"
    SizeChanged="Page_SizeChanged"
    mc:Ignorable="d">

    <Page.Resources>
        <DataTemplate x:Key="PlanRowTemplate" x:DataType="pages:PlanListRow">
            <Grid Padding="8,6" RowDefinitions="Auto,Auto">
                <TextBlock Text="{x:Bind PlanName, Mode=OneWay}" Style="{ThemeResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Row="1" Text="{x:Bind CourseCount, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid x:Name="RootGrid" ColumnDefinitions="320,*" RowDefinitions="Auto,*" RowSpacing="12" Style="{StaticResource ManagementRootGridStyle}">
        <TextBlock x:Name="PageTitle" Margin="{StaticResource ManagementLeadingInset}" Text="" Style="{ThemeResource TitleTextBlockStyle}" />

        <CommandBar
            x:Name="PlanCommandBar"
            AutomationProperties.AutomationId="PlanManagerCommandBar"
            Grid.Column="1"
            Background="Transparent"
            DefaultLabelPosition="Right"
            HorizontalAlignment="Stretch"
            Margin="{StaticResource ManagementTrailingInset}">
            <AppBarButton x:Name="NewPlanButton" AutomationProperties.AutomationId="PlanManagerNewPlanButton" Label="" Click="NewPlan_Click" />
            <AppBarButton x:Name="OpenPlanButton" AutomationProperties.AutomationId="PlanManagerOpenPlanButton" Icon="OpenFile" Label="" Click="OpenPlan_Click" />
            <AppBarButton x:Name="CopyPlanButton" AutomationProperties.AutomationId="PlanManagerCopyPlanButton" Icon="Copy" Label="" Click="CopyPlan_Click" />
            <AppBarButton x:Name="RenamePlanButton" AutomationProperties.AutomationId="PlanManagerRenamePlanButton" Icon="Edit" Label="" Click="RenamePlan_Click" />
            <AppBarButton x:Name="ClearPlanButton" AutomationProperties.AutomationId="PlanManagerClearPlanButton" Icon="Clear" Label="" Click="ClearPlan_Click" />
            <AppBarButton x:Name="DeletePlanButton" AutomationProperties.AutomationId="PlanManagerDeletePlanButton" Icon="Delete" Label="" Click="DeletePlan_Click" />
        </CommandBar>

        <Grid x:Name="PlanListPane" Grid.Row="1" Margin="{StaticResource ManagementLeadingInset}" RowDefinitions="Auto,*" RowSpacing="12">
            <appControls:WheelSafeComboBox x:Name="SemesterFilterBox" AutomationProperties.AutomationId="PlanManagerSemesterFilterBox" SelectionChanged="SemesterFilterBox_SelectionChanged" />
            <ListView
                x:Name="PlanList"
                AutomationProperties.AutomationId="PlanManagerList"
                Grid.Row="1"
                ItemTemplate="{StaticResource PlanRowTemplate}"
                SelectionChanged="PlanList_SelectionChanged"
                SelectionMode="Single" />
        </Grid>

        <ScrollViewer
            x:Name="PlanContentScrollViewer"
            AutomationProperties.AutomationId="PlanContentScrollViewer"
            Grid.Row="1"
            Grid.Column="1"
            Style="{StaticResource ManagementScrollViewerStyle}">
            <Grid x:Name="PlanContentHost" AutomationProperties.AutomationId="PlanContentHost">
                <StackPanel
                    x:Name="PlanContentStack"
                    AutomationProperties.AutomationId="PlanContentStack"
                    Style="{StaticResource ManagementContentStackStyle}">
                    <Border Style="{StaticResource AppCardSurfaceStyle}">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="10">
                            <TextBlock x:Name="SelectedPlanTitle" Text="" Style="{ThemeResource SubtitleTextBlockStyle}" TextWrapping="Wrap" />
                            <TextBlock x:Name="SelectedPlanSemester" Grid.Row="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="SelectedPlanCredits" Grid.Row="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="SelectedPlanModified" Grid.Row="3" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ListView x:Name="PlanCourseList" Grid.Row="4" Header="">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="pages:PlanCourseRow">
                                        <StackPanel Padding="4">
                                            <TextBlock Text="{x:Bind CourseName, Mode=OneWay}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                            <appControls:MeetingTimesPresenter ItemsSource="{x:Bind Meetings, Mode=OneWay}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
