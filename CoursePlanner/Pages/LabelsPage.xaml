<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="CoursePlanner.Pages.LabelsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:appControls="using:CoursePlanner.Controls"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="using:CoursePlanner.Pages"
    Background="Transparent"
    SizeChanged="Page_SizeChanged"
    mc:Ignorable="d">

    <Page.Resources>
        <CollectionViewSource x:Name="LabelGroupsViewSource" IsSourceGrouped="True" />
    </Page.Resources>

    <Grid x:Name="RootGrid" ColumnDefinitions="320,*" ColumnSpacing="12" Style="{StaticResource ManagementRootGridStyle}">

        <Grid x:Name="LabelListPane" Margin="{StaticResource ManagementLeadingInset}" RowDefinitions="Auto,*" RowSpacing="12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" MinHeight="48" Padding="{StaticResource ManagementListHeaderActionInset}">
                <TextBlock
                    x:Name="PageTitle"
                    VerticalAlignment="Center"
                    Style="{ThemeResource TitleTextBlockStyle}"
                    Text=""
                    TextTrimming="CharacterEllipsis" />
                <Button
                    x:Name="NewLabelButton"
                    AutomationProperties.AutomationId="NewLabelButton"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Click="NewLabel_Click"
                    Style="{StaticResource ManagementAddButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <FontIcon FontSize="16" Glyph="&#xE710;" />
                        <TextBlock x:Name="NewLabelText" VerticalAlignment="Center" Text="" TextWrapping="NoWrap" />
                    </StackPanel>
                </Button>
            </Grid>

            <ListView
                x:Name="LabelList"
                AutomationProperties.AutomationId="LabelList"
                Grid.Row="1"
                ItemsSource="{x:Bind LabelGroupsViewSource.View, Mode=OneWay}"
                SelectionChanged="LabelList_SelectionChanged"
                SelectionMode="Single">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsStackPanel AreStickyGroupHeadersEnabled="False" />
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate x:DataType="pages:LabelGroup">
                                <TextBlock
                                    Margin="12,14,12,6"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                                    Text="{x:Bind Key}" />
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListView.GroupStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="pages:LabelListRow">
                        <Grid MinHeight="44" Padding="20,7,12,7">
                            <TextBlock
                                VerticalAlignment="Center"
                                Style="{ThemeResource BodyStrongTextBlockStyle}"
                                Text="{x:Bind Name}"
                                TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <ScrollViewer
            x:Name="ContentScrollViewer"
            AutomationProperties.AutomationId="ContentScrollViewer"
            Grid.Column="1"
            Style="{StaticResource ManagementScrollViewerStyle}">
            <Grid x:Name="ContentHost" AutomationProperties.AutomationId="ContentHost">
                <StackPanel
                    x:Name="ContentStack"
                    AutomationProperties.AutomationId="ContentStack"
                    Style="{StaticResource ManagementContentStackStyle}">
                <controls:SettingsCard
                    x:Name="LabelEditorCard"
                    Header=""
                    Description=""
                    ContentAlignment="Left">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                        <TextBox
                            x:Name="LabelNameBox"
                            AutomationProperties.AutomationId="LabelNameBox"
                            Header=""
                            MaxLength="2048" />
                        <appControls:WheelSafeComboBox
                            x:Name="LabelKindBox"
                            AutomationProperties.AutomationId="LabelKindBox"
                            Grid.Row="1"
                            Header=""
                            Width="260" />
                    </Grid>
                </controls:SettingsCard>

                <StackPanel
                    x:Name="LabelActionsPanel"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        x:Name="MoveLabelUpButton"
                        AutomationProperties.AutomationId="MoveLabelUpButton"
                        Content=""
                        Click="MoveLabelUp_Click" />
                    <Button
                        x:Name="MoveLabelDownButton"
                        AutomationProperties.AutomationId="MoveLabelDownButton"
                        Content=""
                        Click="MoveLabelDown_Click" />
                    <Button
                        x:Name="SaveLabelButton"
                        AutomationProperties.AutomationId="SaveLabelButton"
                        Content=""
                        Click="SaveLabel_Click"
                        Style="{StaticResource AccentButtonStyle}" />
                    <Button
                        x:Name="DeleteLabelButton"
                        AutomationProperties.AutomationId="DeleteLabelButton"
                        Content=""
                        Click="DeleteLabel_Click" />
                </StackPanel>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
