            <StaticResource x:Key="AppPickerHoverBrush" ResourceKey="SystemColorHighlightColorBrush" />
            <StaticResource x:Key="AppPickerPressedBrush" ResourceKey="SystemColorHighlightColorBrush" />
            <StaticResource x:Key="AppPickerSelectedBrush" ResourceKey="SystemColorHighlightColorBrush" />
            <StaticResource x:Key="AppPickerSelectedTextBrush" ResourceKey="SystemColorHighlightTextColorBrush" />
            <StaticResource x:Key="AppPickerSoftSelectedBrush" ResourceKey="SystemColorHighlightColorBrush" />
            <StaticResource x:Key="AppPickerMutedTextBrush" ResourceKey="SystemColorWindowTextColorBrush" />
            <StaticResource x:Key="AppCalendarHeaderHoverBrush" ResourceKey="SystemColorHighlightColorBrush" />
            <StaticResource x:Key="AppCalendarHeaderPressedBrush" ResourceKey="SystemColorHighlightColorBrush" />
            <StaticResource x:Key="AppCalendarDateHoverBrush" ResourceKey="SystemColorHighlightColorBrush" />
            <StaticResource x:Key="AppCalendarDatePressedBrush" ResourceKey="SystemColorHighlightColorBrush" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
