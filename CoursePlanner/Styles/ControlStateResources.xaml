<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="AppInteractiveTextBrush" Color="#1A1A1A" />
            <SolidColorBrush x:Key="AppControlHoverBrush" Color="#09000000" />
            <StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="AppControlHoverBrush" />
            <StaticResource x:Key="ToggleButtonBackgroundPointerOver" ResourceKey="AppControlHoverBrush" />
            <StaticResource x:Key="RepeatButtonBackgroundPointerOver" ResourceKey="AppControlHoverBrush" />
            <StaticResource x:Key="HyperlinkButtonBackgroundPointerOver" ResourceKey="AppControlHoverBrush" />
            <StaticResource x:Key="AppBarButtonBackgroundPointerOver" ResourceKey="AppControlHoverBrush" />
            <StaticResource x:Key="AppBarToggleButtonBackgroundPointerOver" ResourceKey="AppControlHoverBrush" />
            <SolidColorBrush x:Key="AppTitleBarHoverBrush" Color="#14000000" />
            <SolidColorBrush x:Key="AppTitleBarPressedBrush" Color="#20000000" />
            <SolidColorBrush x:Key="AppShellTabRestBrush" Color="Transparent" />
            <SolidColorBrush x:Key="AppShellTabSelectedBrush" Color="#F7FFFFFF" />
            <SolidColorBrush x:Key="AppShellTabHoverBrush" Color="#14000000" />

            <SolidColorBrush x:Key="AppPickerEditorBrush" Color="#F7FFFFFF" />
            <SolidColorBrush x:Key="AppPickerEditorStrokeBrush" Color="#3D000000" />
            <SolidColorBrush x:Key="AppPickerHoverBrush" Color="#14000000" />
            <SolidColorBrush x:Key="AppPickerPressedBrush" Color="#20000000" />
            <SolidColorBrush x:Key="AppPickerSelectedBrush" Color="#00857A" />
            <SolidColorBrush x:Key="AppPickerSelectedTextBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="AppPickerSoftSelectedBrush" Color="#D8F0EA" />
            <SolidColorBrush x:Key="AppPickerMutedTextBrush" Color="#575F5C" />
            <SolidColorBrush x:Key="AppCalendarHeaderHoverBrush" Color="#14000000" />
            <SolidColorBrush x:Key="AppCalendarHeaderPressedBrush" Color="#20000000" />
            <SolidColorBrush x:Key="AppCalendarDateHoverBrush" Color="#14000000" />
            <SolidColorBrush x:Key="AppCalendarDatePressedBrush" Color="#20000000" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="AppInteractiveTextBrush" Color="#F5F7F6" />
            <SolidColorBrush x:Key="AppControlHoverBrush" Color="#16FFFFFF" />
            <StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="AppControlHoverBrush" />
            <StaticResource x:Key="ToggleButtonBackgroundPointerOver" ResourceKey="AppControlHoverBrush" />
            <StaticResource x:Key="RepeatButtonBackgroundPointerOver" ResourceKey="AppControlHoverBrush" />
            <StaticResource x:Key="HyperlinkButtonBackgroundPointerOver" ResourceKey="AppControlHoverBrush" />
            <StaticResource x:Key="AppBarButtonBackgroundPointerOver" ResourceKey="AppControlHoverBrush" />
            <StaticResource x:Key="AppBarToggleButtonBackgroundPointerOver" ResourceKey="AppControlHoverBrush" />
            <SolidColorBrush x:Key="AppTitleBarHoverBrush" Color="#19FFFFFF" />
            <SolidColorBrush x:Key="AppTitleBarPressedBrush" Color="#26FFFFFF" />
            <SolidColorBrush x:Key="AppShellTabRestBrush" Color="Transparent" />
            <SolidColorBrush x:Key="AppShellTabSelectedBrush" Color="#F42B302E" />
            <SolidColorBrush x:Key="AppShellTabHoverBrush" Color="#19FFFFFF" />

            <SolidColorBrush x:Key="AppPickerEditorBrush" Color="#F22D312F" />
            <SolidColorBrush x:Key="AppPickerEditorStrokeBrush" Color="#3DFFFFFF" />
            <SolidColorBrush x:Key="AppPickerHoverBrush" Color="#19FFFFFF" />
            <SolidColorBrush x:Key="AppPickerPressedBrush" Color="#26FFFFFF" />
            <SolidColorBrush x:Key="AppPickerSelectedBrush" Color="#72DED0" />
            <SolidColorBrush x:Key="AppPickerSelectedTextBrush" Color="#0B2622" />
            <SolidColorBrush x:Key="AppPickerSoftSelectedBrush" Color="#264640" />
            <SolidColorBrush x:Key="AppPickerMutedTextBrush" Color="#C5CECB" />
            <SolidColorBrush x:Key="AppCalendarHeaderHoverBrush" Color="#19FFFFFF" />
            <SolidColorBrush x:Key="AppCalendarHeaderPressedBrush" Color="#26FFFFFF" />
            <SolidColorBrush x:Key="AppCalendarDateHoverBrush" Color="#19FFFFFF" />
            <SolidColorBrush x:Key="AppCalendarDatePressedBrush" Color="#26FFFFFF" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="HighContrast">
            <StaticResource x:Key="AppInteractiveTextBrush" ResourceKey="SystemColorHighlightTextColorBrush" />
            <StaticResource x:Key="AppControlHoverBrush" ResourceKey="SystemColorHighlightColorBrush" />
            <StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="AppControlHoverBrush" />
            <StaticResource x:Key="ToggleButtonBackgroundPointerOver" ResourceKey="AppControlHoverBrush" />
            <StaticResource x:Key="RepeatButtonBackgroundPointerOver" ResourceKey="AppControlHoverBrush" />
            <StaticResource x:Key="HyperlinkButtonBackgroundPointerOver" ResourceKey="AppControlHoverBrush" />
            <StaticResource x:Key="AppBarButtonBackgroundPointerOver" ResourceKey="AppControlHoverBrush" />
            <StaticResource x:Key="AppBarToggleButtonBackgroundPointerOver" ResourceKey="AppControlHoverBrush" />
            <StaticResource x:Key="AppTitleBarHoverBrush" ResourceKey="SystemColorHighlightColorBrush" />
            <StaticResource x:Key="AppTitleBarPressedBrush" ResourceKey="SystemColorHighlightColorBrush" />
            <StaticResource x:Key="AppShellTabRestBrush" ResourceKey="SystemColorWindowColorBrush" />
            <StaticResource x:Key="AppShellTabSelectedBrush" ResourceKey="SystemColorWindowColorBrush" />
            <StaticResource x:Key="AppShellTabHoverBrush" ResourceKey="SystemColorWindowColorBrush" />

            <StaticResource x:Key="AppPickerEditorBrush" ResourceKey="SystemColorButtonFaceColorBrush" />
