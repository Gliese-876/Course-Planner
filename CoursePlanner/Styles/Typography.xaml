<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <FontFamily x:Key="AppTextFontFamily">ms-appx:///Assets/Fonts/DreamHanSansSC/DreamHanSans-W12.ttc#Dream Han Sans SC</FontFamily>
    <FontFamily x:Key="AppTextItalicFontFamily">ms-appx:///Assets/Fonts/DreamHanSansSC/DreamHanSans-W12.ttc#Dream Han Sans SC</FontFamily>
    <FontFamily x:Key="AppTextLightFontFamily">ms-appx:///Assets/Fonts/DreamHanSansSC/DreamHanSans-W4.ttc#Dream Han Sans SC</FontFamily>
    <FontFamily x:Key="AppTextSemiBoldFontFamily">ms-appx:///Assets/Fonts/DreamHanSansSC/DreamHanSans-W16.ttc#Dream Han Sans SC</FontFamily>
    <FontFamily x:Key="AppTextBoldFontFamily">ms-appx:///Assets/Fonts/DreamHanSansSC/DreamHanSans-W22.ttc#Dream Han Sans SC</FontFamily>
    <FontFamily x:Key="CourseBlockTextFontFamily">ms-appx:///Assets/Fonts/DreamHanSansSC/DreamHanSans-W12.ttc#Dream Han Sans SC</FontFamily>
    <FontFamily x:Key="CourseBlockTextBoldFontFamily">ms-appx:///Assets/Fonts/DreamHanSansSC/DreamHanSans-W22.ttc#Dream Han Sans SC</FontFamily>
    <FontFamily x:Key="ContentControlThemeFontFamily">ms-appx:///Assets/Fonts/DreamHanSansSC/DreamHanSans-W12.ttc#Dream Han Sans SC</FontFamily>
    <FontFamily x:Key="MTCMediaFontFamily">ms-appx:///Assets/Fonts/DreamHanSansSC/DreamHanSans-W12.ttc#Dream Han Sans SC</FontFamily>
    <FontFamily x:Key="PivotHeaderItemFontFamily">ms-appx:///Assets/Fonts/DreamHanSansSC/DreamHanSans-W12.ttc#Dream Han Sans SC</FontFamily>
    <FontFamily x:Key="PivotTitleFontFamily">ms-appx:///Assets/Fonts/DreamHanSansSC/DreamHanSans-W12.ttc#Dream Han Sans SC</FontFamily>
    <FontFamily x:Key="KeyTipFontFamily">ms-appx:///Assets/Fonts/DreamHanSansSC/DreamHanSans-W12.ttc#Dream Han Sans SC</FontFamily>
    <FontFamily x:Key="PhoneFontFamilyNormal">ms-appx:///Assets/Fonts/DreamHanSansSC/DreamHanSans-W12.ttc#Dream Han Sans SC</FontFamily>
    <FontFamily x:Key="PhoneFontFamilySemiLight">ms-appx:///Assets/Fonts/DreamHanSansSC/DreamHanSans-W4.ttc#Dream Han Sans SC</FontFamily>
    <x:Double x:Key="AppBodyTextLineHeight">21</x:Double>
    <x:Double x:Key="AppBodyStrongTextLineHeight">21</x:Double>
    <x:Double x:Key="AppTitleTextLineHeight">41</x:Double>
    <x:Double x:Key="AppSubtitleTextLineHeight">29</x:Double>
    <x:Double x:Key="AppCaptionTextLineHeight">18</x:Double>
    <x:Double x:Key="AppPickerDisplayTextLineHeight">21</x:Double>
    <x:Double x:Key="AppToolbarTextLineHeight">19</x:Double>
    <x:Double x:Key="AppClockDigitTextFontSize">36</x:Double>
    <x:Double x:Key="AppClockDigitTextLineHeight">53</x:Double>

    <Style x:Key="BaseTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{ThemeResource AppTextFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource BodyTextBlockFontSize}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="{ThemeResource AppBodyTextLineHeight}" />
        <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
        <Setter Property="TextLineBounds" Value="Full" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="TitleTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
        <Setter Property="FontFamily" Value="{ThemeResource AppTextSemiBoldFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource TitleTextBlockFontSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="{ThemeResource AppTitleTextLineHeight}" />
        <Setter Property="OpticalMarginAlignment" Value="TrimSideBearings" />
    </Style>

    <Style x:Key="SubtitleTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
        <Setter Property="FontFamily" Value="{ThemeResource AppTextSemiBoldFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource SubtitleTextBlockFontSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="{ThemeResource AppSubtitleTextLineHeight}" />
        <Setter Property="OpticalMarginAlignment" Value="TrimSideBearings" />
    </Style>

    <Style x:Key="BodyTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}" />

    <Style x:Key="BodyStrongTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
        <Setter Property="FontFamily" Value="{ThemeResource AppTextSemiBoldFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource BodyStrongTextBlockFontSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="{ThemeResource AppBodyStrongTextLineHeight}" />
    </Style>

    <Style x:Key="CaptionTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
        <Setter Property="FontSize" Value="{StaticResource CaptionTextBlockFontSize}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="{ThemeResource AppCaptionTextLineHeight}" />
    </Style>

    <Style x:Key="BaseRichTextBlockStyle" TargetType="RichTextBlock">
        <Setter Property="FontFamily" Value="{ThemeResource AppTextFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource BodyTextBlockFontSize}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="{ThemeResource AppBodyTextLineHeight}" />
        <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
        <Setter Property="TextLineBounds" Value="Full" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="BodyRichTextBlockStyle" TargetType="RichTextBlock" BasedOn="{StaticResource BaseRichTextBlockStyle}" />

    <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}" />
    <Style TargetType="RichTextBlock" BasedOn="{StaticResource BodyRichTextBlockStyle}" />
</ResourceDictionary>
