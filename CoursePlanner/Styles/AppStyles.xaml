<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:services="using:CoursePlanner.Services">

    <Thickness x:Key="PagePadding">20,16,20,20</Thickness>
    <Thickness x:Key="ManagementPagePadding">0,16,0,0</Thickness>
    <Thickness x:Key="ManagementLeadingInset">20,0,0,0</Thickness>
    <Thickness x:Key="ManagementTrailingInset">0,0,20,0</Thickness>
    <Thickness x:Key="ManagementListHeaderActionInset">0,0,4,0</Thickness>
    <CornerRadius x:Key="NavigationViewContentGridCornerRadius">0</CornerRadius>

    <Style x:Key="PanelHeaderTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyStrongTextBlockStyle}">
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="ManagementRootGridStyle" TargetType="Grid">
        <Setter Property="Padding" Value="{StaticResource ManagementPagePadding}" />
        <Setter Property="ColumnSpacing" Value="20" />
        <Setter Property="services:AppMaterialLayer.Surface" Value="Page" />
        <Setter Property="services:AppAnimationLayer.Profile" Value="DynamicChildren" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style x:Key="ManagementContentStackStyle" TargetType="StackPanel">
        <Setter Property="Spacing" Value="16" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="ManagementScrollViewerStyle" TargetType="ScrollViewer">
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="HorizontalScrollMode" Value="Disabled" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="VerticalScrollMode" Value="Enabled" />
    </Style>

    <Style x:Key="AppCardSurfaceStyle" TargetType="Border">
        <Setter Property="services:AppMaterialLayer.Surface" Value="Card" />
        <Setter Property="Background" Value="{ThemeResource AppMaterialCardBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <Style
        x:Key="AppTransientFlyoutPresenterStyle"
        TargetType="FlyoutPresenter"
        BasedOn="{StaticResource DefaultFlyoutPresenterStyle}">
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="ManagementAddButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
        <Setter Property="Height" Value="34" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="PlannerSidePaneSurfaceStyle" TargetType="Border">
        <Setter Property="services:AppMaterialLayer.Surface" Value="DockedPane" />
    </Style>

    <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="10,2" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="{ThemeResource SubtleFillColorTransparentBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource SubtleFillColorTransparentBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
    </Style>
</ResourceDictionary>
