<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="CoursePlanner.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CoursePlanner">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="SystemAccentColor">#00857A</Color>
                    <Color x:Key="SystemAccentColorLight1">#14958B</Color>
                    <Color x:Key="SystemAccentColorLight2">#4AB5AA</Color>
                    <Color x:Key="SystemAccentColorLight3">#A8DDD7</Color>
                    <Color x:Key="SystemAccentColorDark1">#00756C</Color>
                    <Color x:Key="SystemAccentColorDark2">#00645D</Color>
                    <Color x:Key="SystemAccentColorDark3">#005149</Color>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#00857A" />
                    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#00776F" />
                    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#006961" />
                    <SolidColorBrush x:Key="AccentFillColorDisabledBrush" Color="#6600857A" />
                    <SolidColorBrush x:Key="AccentFillColorSelectedTextBackgroundBrush" Color="#00857A" />
                    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#007C75" />
                    <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="#006E68" />
                    <SolidColorBrush x:Key="AccentTextFillColorTertiaryBrush" Color="#005E58" />
                    <SolidColorBrush x:Key="AccentTextFillColorDisabledBrush" Color="#66007C75" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="SystemAccentColor">#72DED0</Color>
                    <Color x:Key="SystemAccentColorLight1">#8AE6DB</Color>
                    <Color x:Key="SystemAccentColorLight2">#A8EEE6</Color>
                    <Color x:Key="SystemAccentColorLight3">#D2F7F3</Color>
                    <Color x:Key="SystemAccentColorDark1">#58C9BC</Color>
                    <Color x:Key="SystemAccentColorDark2">#3DAEA2</Color>
                    <Color x:Key="SystemAccentColorDark3">#278F86</Color>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#72DED0" />
                    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#83E4D8" />
                    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#58C9BC" />
                    <SolidColorBrush x:Key="AccentFillColorDisabledBrush" Color="#6672DED0" />
                    <SolidColorBrush x:Key="AccentFillColorSelectedTextBackgroundBrush" Color="#72DED0" />
                    <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#72DED0" />
                    <SolidColorBrush x:Key="AccentTextFillColorSecondaryBrush" Color="#58C9BC" />
                    <SolidColorBrush x:Key="AccentTextFillColorTertiaryBrush" Color="#3DAEA2" />
                    <SolidColorBrush x:Key="AccentTextFillColorDisabledBrush" Color="#6672DED0" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast" />
            </ResourceDictionary.ThemeDictionaries>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="Styles/MaterialResources.xaml" />
                <ResourceDictionary Source="Styles/ControlStateResources.xaml" />
                <ResourceDictionary Source="Styles/DomainColorResources.xaml" />
                <ResourceDictionary Source="Styles/Typography.xaml" />
                <ResourceDictionary Source="Styles/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
